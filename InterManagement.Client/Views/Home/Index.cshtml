@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Accueil";
    ViewData["PublicNavActive"] = "Accueil";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

@await Html.PartialAsync("~/Views/Shared/_Header.cshtml")

<main class="main" id="main">

    <div class="hero">
        <div class="hero-copy">
            <h1>Chaque stagiaire écrit sa propre réussite.</h1>
            <p>
                Chaque semaine, une graine. Chaque phase, un avancement.
                Un accompagnement humain, pas à pas, du premier jour jusqu'à
                la validation finale.
            </p>
            <a href="#" class="hero-cta login-trigger-hero">Commencer le parcours</a>
        </div>

        <div class="hero-polaroid-wrap">
            <div class="polaroid">
                <div class="polaroid-tape polaroid-tape-left"></div>
                <div class="polaroid-tape polaroid-tape-right"></div>
                <div class="polaroid-badge">Gabera</div>
                <img src="~/img/people.png" alt="Stagiaires et mentors" class="polaroid-photo" />
                <div class="polaroid-caption">nos stagiaires</div>
            </div>
        </div>
    </div>

    <div class="premium-experience">
        <div class="premium-header">
            <h2>Votre parcours vers l'excellence</h2>
            <p>
                Une progression structurée, mentorée et immersive pour transformer
                votre potentiel en expertise.
            </p>
        </div>
        <div class="premium-grid">
            <div class="premium-card">
                <span class="premium-pin"></span>
                <div class="premium-icon">
                    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M24 6c-7 3-14 4-14 4v9c0 8 6 14 14 17 8-3 14-9 14-17v-9s-7-1-14-4Z" />
                        <path d="M18 24l4 4 8-8" />
                    </svg>
                </div>
                <h3>Mentorat personnalisé<span class="premium-underline"><svg viewBox="0 0 140 8" preserveAspectRatio="none" aria-hidden="true"><path d="M1 5 Q 35 1, 70 4 T 139 3 L139 7 Q 70 9, 1 7 Z" /></svg></span></h3>
                <p>Un accompagnement sur mesure avec des experts dédiés à votre réussite.</p>
            </div>
            <div class="premium-card">
                <span class="premium-pin"></span>
                <div class="premium-icon">
                    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="8" y="10" width="32" height="30" rx="3" />
                        <path d="M8 18h32M16 6v8M32 6v8" />
                        <path d="M16 26l4 4 8-9" />
                    </svg>
                </div>
                <h3>Progression hebdomadaire<span class="premium-underline"><svg viewBox="0 0 140 8" preserveAspectRatio="none" aria-hidden="true"><path d="M1 5 Q 35 1, 70 4 T 139 3 L139 7 Q 70 9, 1 7 Z" /></svg></span></h3>
                <p>Un suivi régulier pour mesurer vos avancées étape par étape.</p>
            </div>
            <div class="premium-card">
                <span class="premium-pin"></span>
                <div class="premium-icon">
                    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 40V22M18 40V14M28 40V26M38 40V8" />
                        <path d="M6 16l10-8 10 6 12-10" />
                    </svg>
                </div>
                <h3>Suivi intelligent<span class="premium-underline"><svg viewBox="0 0 140 8" preserveAspectRatio="none" aria-hidden="true"><path d="M1 5 Q 35 1, 70 4 T 139 3 L139 7 Q 70 9, 1 7 Z" /></svg></span></h3>
                <p>Des outils modernes pour visualiser votre évolution en temps réel.</p>
            </div>
            <div class="premium-card">
                <span class="premium-pin"></span>
                <div class="premium-icon">
                    <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="24" cy="24" r="4" />
                        <circle cx="10" cy="34" r="3" />
                        <circle cx="38" cy="34" r="3" />
                        <circle cx="10" cy="12" r="3" />
                        <circle cx="38" cy="12" r="3" />
                        <path d="M13 32l8-6M35 32l-8-6M13 15l8 6M35 15l-8 6" />
                    </svg>
                </div>
                <h3>Évolution par phase<span class="premium-underline"><svg viewBox="0 0 140 8" preserveAspectRatio="none" aria-hidden="true"><path d="M1 5 Q 35 1, 70 4 T 139 3 L139 7 Q 70 9, 1 7 Z" /></svg></span></h3>
                <p>Une structuration claire en 4 phases pour maîtriser chaque étape.</p>
            </div>
        </div>
    </div>

    <div class="offre-section">
        <div class="offre-grid-alt">
            <div class="carte-offre-alt">
                <div class="image-container-alt">
                    <img src="~/img/people.png" alt="Formation" class="visuel-offre-alt" />
                </div>
                <h3 class="offre-title-alt">Formations excellence</h3>
                <p class="offre-desc-alt">
                    Programme complet de développement professionnel. Cours intensifs
                    et projets pratiques.
                </p>
                <a href="#" class="lien-subtil-alt">découvrir →</a>
            </div>
            <div class="carte-offre-alt">
                <div class="image-container-alt">
                    <img src="~/img/people.png" alt="Stage" class="visuel-offre-alt" />
                </div>
                <h3 class="offre-title-alt">Stages immersion</h3>
                <p class="offre-desc-alt">
                    Expérience professionnelle en entreprise. Mise en pratique des
                    compétences acquises.
                </p>
                <a href="#" class="lien-subtil-alt">découvrir →</a>
            </div>
        </div>
    </div>

    <div class="quote-premium">
        <div class="quote-text-premium">"Notre Mission"</div>
        <div class="quote-desc-premium">
            Fournir des logiciels, des technologie de pointe et des solutions de
            formation des spéciale en TIC et leadership ...
        </div>
    </div>

</main>

@await Html.PartialAsync("_Footer")
@await Html.PartialAsync("_LoginModal")

@section Scripts {
    <script src="~/js/site-public.js"></script>
}
