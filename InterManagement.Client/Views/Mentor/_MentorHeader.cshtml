@*
=================================================
HEADER ESPACE MENTOR
=================================================
*@
@model InterManagement.Client.Models.MentorViewModel

<header class="header" id="header">
    <div class="header-container">
        <a asp-controller="Home" asp-action="Index" class="logo">GABERA<span class="logo-dot"></span></a>

        <div class="nav">
            <a asp-controller="Home" asp-action="Index" class="nav-link">Accueil</a>
            <a asp-controller="Stagiaire" asp-action="Index" class="nav-link">Stagiaire</a>
            <a asp-controller="MentorSpace" asp-action="Index" asp-route-mentorId="@Model.MentorId" class="nav-link active">Mentor</a>
        </div>

        <div class="nav-actions">
            <div class="account-dimension">
                <button class="action-btn" id="accountTrigger">
                    <i class="far fa-user"></i>
                    <span class="action-tooltip">Compte</span>
                </button>
                <div class="account-panel" id="accountPanel">
                    <div class="panel-dimension">
                        <div class="panel-header">
                            <div class="panel-icon"><i class="far fa-user"></i></div>
                            <div>
                                <div class="panel-title">Bienvenue</div>
                                <div class="panel-sub">Connectez-vous</div>
                            </div>
                        </div>
                        <div class="panel-items">
                            <a href="#" class="panel-link" id="loginTrigger">
                                <i class="fas fa-sign-in-alt"></i>Connexion
                            </a>
                            <div class="panel-divider"></div>
                            <a href="#" class="panel-link" id="logoutTrigger">
                                <i class="fas fa-sign-out-alt"></i>Déconnexion
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
