@*
=================================================
TABLEAU STAGIAIRES
Liste tous les stagiaires avec leurs actions.
=================================================
*@
@model List<InterManagement.Application.Features.Trainees.DTOs.TraineeDto>

<div class="table-container">
    <div class="table-header">
        <h3><i class="fas fa-user-graduate"></i> Stagiaires</h3>
    </div>
    <div style="overflow-x: auto">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Stagiaire</th>
                    <th>Email</th>
                    <th>Spécialité</th>
                    <th>Structure</th>
                    <th>Date début</th>
                    <th>Date fin</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="stagiairesList">
                @if (!Model.Any())
                {
                    <tr><td colspan="8" style="text-align:center;">Aucun stagiaire</td></tr>
                }
                else
                {
                    @foreach (var s in Model)
                    {
                        var isActive = s.IsActive;
                        var activeLabel = isActive ? "Actif" : "Inactif";
                        var isCompleted = s.Status == InterManagement.Shared.Enums.TraineeStatus.Completed;
                        var badgeLabel = !isActive ? "Inactif" : isCompleted ? "Terminé" : "Actif";
                        <tr data-user-id="@s.Id"
                            data-user-type="stagiaire"
                            data-nom="@s.LastName"
                            data-prenom="@s.FirstName"
                            data-email="@s.Email"
                            data-specialite="@s.Specialty"
                            data-structure="@s.University"
                            data-theme="@s.Theme"
                            data-date-debut="@s.StartDate.ToString("yyyy-MM-dd")"
                            data-date-fin="@s.EndDate.ToString("yyyy-MM-dd")"
                            data-statut="@activeLabel"
                            data-trainee-status="@s.Status">

                            <td><div class="avatar">@s.FirstName[0]@s.LastName[0]</div> @s.FirstName @s.LastName</td>
                            <td>@s.Email</td>
                            <td>@s.Specialty</td>
                            <td>@s.University</td>
                            <td>@s.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@s.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @await Html.PartialAsync("~/Views/Shared/Components/_StatusBadge.cshtml", badgeLabel)
                            </td>
                            <td class="action-btns">
                                @if (isActive)
                                {
                                    <button class="action-btn view"
                                            onclick="openTraineeDetailsModal(this)"
                                            aria-label="Voir @s.FirstName @s.LastName">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="action-btn edit"
                                            onclick="openEditUserModal(this)"
                                            aria-label="Modifier @s.FirstName @s.LastName">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <form id="deleteStagiaireForm-@s.Id"
                                          asp-controller="Utilisateurs"
                                          asp-action="DeleteStagiaire"
                                          asp-route-id="@s.Id"
                                          method="post"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="button"
                                                class="action-btn delete"
                                                data-delete-form-id="deleteStagiaireForm-@s.Id"
                                                data-delete-name="@s.FirstName @s.LastName"
                                                aria-label="Supprimer @s.FirstName @s.LastName">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="action-btn view disabled" aria-label="Utilisateur inactif">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                    <button class="action-btn edit" disabled aria-label="Utilisateur inactif">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <button class="action-btn delete" disabled aria-label="Utilisateur inactif">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
