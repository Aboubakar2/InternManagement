@*
=================================================
PAGE SUIVI DES STAGIAIRES
=================================================
*@
@model InterManagement.Client.Models.SuiviViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Suivi des stagiaires";
    ViewData["ActivePage"] = "suivi";
}

<div class="head-title">
    <div>
        <h1>Suivi des stagiaires</h1>
        <div class="breadcrumb">
            <span>Accueil</span>
            <i class="fas fa-chevron-right"></i>
            <span>Suivi</span>
        </div>
    </div>
</div>

<div class="tabs-section">
    <div class="tab-nav">
        <button class="tab-btn active" data-tab-target="suivi">
            <i class="fas fa-chart-line"></i> Suivi
            <span class="tab-count">@Model.Suivis.Count</span>
        </button>
        <button class="tab-btn" data-tab-target="suivi-importe">
            <i class="fas fa-file-import"></i> Suivi importé
            <span class="tab-count">@Model.SuivisImportes.Count</span>
        </button>
    </div>

    <div class="tab-panel active" data-tab-panel="suivi">
        @await Html.PartialAsync("_SuiviTable", Model.Suivis)
    </div>
    <div class="tab-panel" data-tab-panel="suivi-importe">
        @await Html.PartialAsync("_SuiviImporteTable", Model.SuivisImportes)
    </div>
</div>

@await Html.PartialAsync("_SuiviModal", Model)
@await Html.PartialAsync("_ImportModal")
@await Html.PartialAsync("_CommentaireModal")



@section Scripts {
    <script src="~/js/suivi.js"></script>
}
