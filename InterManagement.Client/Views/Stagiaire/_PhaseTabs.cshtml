@*
=================================================
ONGLETS DE NAVIGATION DES PHASES
=================================================
*@
@model List<InterManagement.Client.Models.StagiairePhaseItem>

<div class="phase-orbit">
    @for (int i = 0; i < Model.Count; i++)
    {
        <button class="phase-orbit-btn @(i == 0 ? "active" : "")" data-phase="@Model[i].PhaseNumber">
            Phase @Model[i].PhaseNumber
        </button>
    }
</div>
