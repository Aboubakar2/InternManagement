@*
=================================================
SIDEBAR
Navigation principale de l'espace Admin.
ViewData["ActivePage"] détermine quel item est
surligné comme actif (défini par chaque Controller).
=================================================
*@
<section id="sidebar">
    <div class="brand">
        <i class="fas fa-code"></i>
        <span>Engeenering &amp; tech</span>
    </div>

    <ul class="side-menu">
        <li class="@(ViewData["ActivePage"]?.ToString() == "dashboard" ? "active" : "")"
            data-page="dashboard">
            <a asp-controller="Dashboard" asp-action="Index">
                <i class="fas fa-chart-line"></i><span>Dashboard</span>
            </a>
        </li>
        <li class="@(ViewData["ActivePage"]?.ToString() == "utilisateurs" ? "active" : "")"
            data-page="utilisateurs">
            <a asp-controller="Utilisateurs" asp-action="Index">
                <i class="fas fa-users"></i><span>Utilisateurs</span>
            </a>
        </li>
        <li class="@(ViewData["ActivePage"]?.ToString() == "suivi" ? "active" : "")"
            data-page="suivi">
            <a asp-controller="Suivi" asp-action="Index">
                <i class="fas fa-calendar-check"></i><span>Suivi</span>
            </a>
        </li>
        <li class="@(ViewData["ActivePage"]?.ToString() == "phases" ? "active" : "")"
            data-page="phases">
            <a asp-controller="Phase" asp-action="Index">
                <i class="fas fa-cog"></i><span>Paramètres</span>
            </a>
        </li>
    </ul>

    <ul class="side-menu" style="margin-top: auto">
        <li>
            <a asp-controller="Account" asp-action="Logout" class="logout">
                <i class="fas fa-right-from-bracket"></i><span>Déconnexion</span>
            </a>
        </li>
    </ul>
</section>
