@*
=================================================
BADGE DE STATUT
=================================================
*@
@model string

@{
    var statusClass = Model switch
    {
        "InProgress" or "EnCours" or "En cours" or "Encour" => "status-inprogress",
        "Validated" or "Validé" => "status-validated",
        "Completed" or "Terminé" => "status-Completed",
        "Suspended" or "Suspendu" => "status-suspended",
        "Actif" => "status-actif",
        "Inactif" => "status-Inactif",
        "Reprendre" => "status-EnAttente",
        _ => "status-EnAttente"
    };

    var statusLabel = Model switch
    {
        "InProgress" => "Encour",
        "Validated" => "Validé",
        "Completed" => "Terminé",
        "Suspended" => "Suspendu",
        "Inactif" => "Inactif",
        _ => Model
    };
}

<span class="status-badge @statusClass">@statusLabel</span>
