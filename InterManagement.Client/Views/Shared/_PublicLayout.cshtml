@*
=================================================
LAYOUT PUBLIC
Utilisé uniquement par la page d'accueil (Home).
Pas de sidebar ni navbar admin — header + footer
classiques d'un site vitrine.
=================================================
*@
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GABERA</title>

    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="alternate icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />

    @* Fixe le fond avant même le chargement de common.css : évite le
       flash blanc natif du navigateur entre deux pages (rechargement
       complet, pas de SPA), surtout visible Accueil/Stagiaire/Mentor *@
    <style>html{background:#fdfbf7;}</style>

    <link rel="stylesheet" href="~/css/common.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @await Html.PartialAsync("~/Views/Shared/_ToastMessages.cshtml")

    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)

    @* Même overlay exactement *@
<div id="pageTransition" style="
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: #0a0a0f;
    z-index: 99999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;">
</div>

<script>
(function() {
    const overlay = document.getElementById('pageTransition');

    window.addEventListener('load', function() {
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
    });

    document.addEventListener('click', function(e) {
        const link = e.target.closest('a[href]');
        if (!link) return;

        const href = link.getAttribute('href');
        if (!href || href.startsWith('#')
                  || href.startsWith('javascript')
                  || link.target === '_blank') return;

        e.preventDefault();
        overlay.style.opacity = '1';
        overlay.style.pointerEvents = 'all';

        setTimeout(function() {
            window.location.href = href;
        }, 150);
    });
})();
</script>
</body>
</html>
