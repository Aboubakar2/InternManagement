@*
=================================================
TOAST DE FEEDBACK (succès / échec)
Affiche TempData["SuccessMessage"] / ["ErrorMessage"]
défini par SetSuccess()/SetError() dans BaseController.
Inclus dans _PublicLayout.cshtml et _Layout.cshtml.
=================================================
*@
@{
    var toastSuccess = TempData["SuccessMessage"] as string;
    var toastError = TempData["ErrorMessage"] as string;
}
@if (!string.IsNullOrEmpty(toastSuccess) || !string.IsNullOrEmpty(toastError))
{
    var isError = !string.IsNullOrEmpty(toastError);
    <div id="appToast" class="app-toast @(isError ? "app-toast-error" : "app-toast-success")" role="alert">
        <i class="fas @(isError ? "fa-circle-exclamation" : "fa-circle-check")"></i>
        <span>@(isError ? toastError : toastSuccess)</span>
        <button type="button" class="app-toast-close" onclick="document.getElementById('appToast')?.remove()" aria-label="Fermer">&times;</button>
    </div>

    <style>
        .app-toast {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 6000;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem 1.25rem;
            border-radius: 16px;
            font-family: "Inter", sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            color: white;
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.25);
            max-width: 420px;
            animation: appToastIn 0.3s ease;
        }

        .app-toast-success {
            background: #10b981;
        }

        .app-toast-error {
            background: #ef4444;
        }

        .app-toast i {
            font-size: 1.1rem;
        }

        .app-toast-close {
            background: none;
            border: none;
            color: white;
            opacity: 0.8;
            font-size: 1.2rem;
            line-height: 1;
            cursor: pointer;
            margin-left: auto;
            padding: 0 0 0 0.5rem;
        }

        .app-toast-close:hover {
            opacity: 1;
        }

        @@keyframes appToastIn {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @@media (max-width: 480px) {
            .app-toast {
                left: 16px;
                right: 16px;
                top: 16px;
                max-width: none;
            }
        }
    </style>

    <script>
        (function () {
            var toast = document.getElementById('appToast');
            if (!toast) return;
            setTimeout(function () {
                toast.style.transition = 'opacity 0.3s ease';
                toast.style.opacity = '0';
                setTimeout(function () { toast.remove(); }, 300);
            }, 5000);
        })();
    </script>
}
