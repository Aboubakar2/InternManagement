@*
=================================================
LAYOUT ADMIN
Structure HTML commune à toutes les pages de
l'espace Administrateur : sidebar, navbar, modal
de suppression. Le contenu spécifique de chaque
page s'insère via @RenderBody().
=================================================
*@
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Intern Management</title>

    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="alternate icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png" />

    @* CSS global, partagé par toutes les pages Admin *@
    <link rel="stylesheet" href="~/css/admin-site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

    @* Bibliothèque de lecture Excel, utilisée uniquement par la page Suivi *@
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>

    @* Chaque page peut ajouter son propre CSS ici *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @await Html.PartialAsync("~/Views/Shared/_ToastMessages.cshtml")

    @* ===== SIDEBAR ===== *@
    @await Html.PartialAsync("~/Views/Shared/Components/_Sidebar.cshtml")

    <section id="content">

        @* ===== NAVBAR ===== *@
        @await Html.PartialAsync("~/Views/Shared/Components/_Navbar.cshtml")

        <main>
            @* ===== CONTENU SPÉCIFIQUE À CHAQUE PAGE ===== *@
            @RenderBody()
        </main>

    </section>

    @* ===== MODAL DE SUPPRESSION — partagé par toutes les pages ===== *@
    @await Html.PartialAsync("~/Views/Shared/Components/_DeleteConfirmModal.cshtml")

    @* JS global, chargé sur toutes les pages *@
    <script src="~/js/site.js"></script>

    @* Chaque page ajoute son propre JS ici *@
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Overlay de chargement -->
<div id="pageLoader" style="
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: var(--bg);
    z-index: 9999;
    align-items: center;
    justify-content: center;">
    <div style="text-align: center;">
        <i class="fas fa-circle-notch fa-spin"
           style="font-size: 2rem; color: var(--primary);"></i>
        <p style="color: var(--text-soft); margin-top: 1rem;">
            Chargement...
        </p>
    </div>
</div>

<script>
    // Affiche le loader avant de quitter la page — sauf pour les liens
    // de téléchargement (ex. export Excel) : ils ne rechargent jamais
    // la page, donc "pageshow" ne se déclenche pas et le loader
    // resterait affiché indéfiniment.
    document.addEventListener('click', function(e) {
        const link = e.target.closest('a[href]');
        if (link && !link.href.includes('#')
                 && !link.href.includes('javascript')
                 && !link.classList.contains('export')
                 && link.target !== '_blank') {
            document.getElementById('pageLoader').style.display = 'flex';

            // Filet de sécurité : si aucune nouvelle page ne se charge
            // (téléchargement, erreur réseau...), on masque quand même
            // le loader après quelques secondes plutôt que de bloquer
            // l'interface indéfiniment.
            setTimeout(function() {
                document.getElementById('pageLoader').style.display = 'none';
            }, 6000);
        }
    });

    // Cache le loader quand la page est chargée
    window.addEventListener('pageshow', function() {
        document.getElementById('pageLoader').style.display = 'none';
    });
</script>

</body>
</html>
