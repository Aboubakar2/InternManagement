@model UpdateTraineeDto
@{
    ViewData["Title"] = "Edit Trainee";
    var traineeId = (int)ViewBag.TraineeId;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Edit Trainee</h2>
    <div>
        <a asp-action="Details" asp-route-id="@traineeId" class="btn btn-outline-info">Details</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@traineeId" method="post">
            @Html.AntiForgeryToken()

            <h5 class="mb-3">Personal Info</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                </div>
            </div>

            <h5 class="mb-3">Internship Info</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="University" class="form-label"></label>
                    <input asp-for="University" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Specialty" class="form-label"></label>
                    <input asp-for="Specialty" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Theme" class="form-label"></label>
                    <input asp-for="Theme" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control"
                           value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control"
                           value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                </div>
            </div>

            <h5 class="mb-3">Status</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select"
                            asp-items="Html.GetEnumSelectList<TraineeStatus>()"></select>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
