@model List<TraineeDto>
@{
    ViewData["Title"] = "Trainees";
    var currentStatus = ViewBag.CurrentStatus as TraineeStatus?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Trainees</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Trainee</a>
</div>

<form method="get" class="mb-3 d-flex gap-2 align-items-center">
    <label class="me-1 mb-0">Filter by status:</label>
    <select name="status" class="form-select w-auto">
        <option value="">All</option>
        @foreach (var s in Enum.GetValues<TraineeStatus>())
        {
            <option value="@((int)s)" selected="@(currentStatus.HasValue && currentStatus.Value == s)">@s</option>
        }
    </select>
    <button type="submit" class="btn btn-outline-secondary">Apply</button>
    @if (currentStatus.HasValue)
    {
        <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
    }
</form>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-muted text-center py-5">
        <p>No trainees found.</p>
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>University</th>
                <th>Specialty</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Active</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var trainee in Model)
            {
                <tr>
                    <td>@trainee.FirstName @trainee.LastName</td>
                    <td>@trainee.Email</td>
                    <td>@trainee.University</td>
                    <td>@trainee.Specialty</td>
                    <td>@trainee.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@trainee.EndDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <span class="badge @StatusBadgeClass(trainee.Status)">@trainee.Status</span>
                    </td>
                    <td>
                        @if (trainee.IsActive)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@trainee.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@trainee.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@trainee.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">@Model.Count trainee(s) found.</p>
}

@functions {
    private static string StatusBadgeClass(TraineeStatus status) => status switch
    {
        TraineeStatus.InProgress => "bg-primary",
        TraineeStatus.Completed  => "bg-success",
        TraineeStatus.Suspended  => "bg-warning text-dark",
        _                        => "bg-secondary"
    };
}
