@model CreateTraineeDto
@{
    ViewData["Title"] = "New Trainee";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>New Trainee</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <h5 class="mb-3">Personal Info</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="e.g. Moussa" />
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" placeholder="e.g. Diallo" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="e.g. moussa@email.com" />
                </div>
            </div>

            <h5 class="mb-3">Internship Info</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="University" class="form-label"></label>
                    <input asp-for="University" class="form-control" placeholder="e.g. ESMT" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Specialty" class="form-label"></label>
                    <input asp-for="Specialty" class="form-control" placeholder="e.g. Software Engineering" />
                </div>
                <div class="col-12">
                    <label asp-for="Theme" class="form-label"></label>
                    <input asp-for="Theme" class="form-control" placeholder="e.g. Web Development" />
                </div>
                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Trainee</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
