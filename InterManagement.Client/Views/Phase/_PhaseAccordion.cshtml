@*
=================================================
ACCORDÉON D'UNE PHASE
=================================================
*@
@model InterManagement.Client.Models.PhaseAccordionItem

<div class="phase-accordion" data-phase-num="@Model.PhaseNumber">

    @* ── EN-TÊTE ACCORDÉON ── *@
    <div class="phase-accordion-header">
        <div class="phase-title">
            <i class="fas fa-layer-group"></i>
            <span>
                Phase @Model.PhaseNumber
                @if (!string.IsNullOrEmpty(Model.Title))
                {
                    <span style="font-weight:400; color:var(--text-soft);"> — @Model.Title</span>
                }
            </span>
        </div>
        <i class="fas fa-chevron-down phase-toggle-icon"></i>
    </div>

    @* ── CORPS DE L'ACCORDÉON ── *@
    <div class="phase-accordion-body">

        @if (!Model.Rows.Any())
        {
            <div style="padding:1.5rem; color:var(--text-soft); font-size:0.9rem;">
                <i class="fas fa-inbox" style="margin-right:6px;"></i>
                Aucun stagiaire dans cette phase.
            </div>
        }
        else
        {
            @* Collecte toutes les semaines distinctes de cette phase
               triées par numéro, pour construire les onglets *@
            var allWeeks = Model.Rows
                .SelectMany(r => r.Weeks)
                .GroupBy(w => w.WeekNumber)
                .OrderBy(g => g.Key)
                .Select(g => g.First())
                .ToList();

            var phaseId = "phase" + Model.PhaseNumber;

            @* ── ONGLETS DE SEMAINES ── *@
            @if (!allWeeks.Any())
            {
                <div style="padding:1rem; color:var(--text-soft); font-size:0.9rem;">
                    <i class="fas fa-calendar-times" style="margin-right:6px;"></i>
                    Aucune semaine configurée.
                    Utilisez le bouton "+ Semaine" depuis la liste des stagiaires.
                </div>
            }
            else
            {
                <div class="week-tabs" id="weekTabs@(Model.PhaseNumber)">
                    @for (int i = 0; i < allWeeks.Count; i++)
                    {
                        var w = allWeeks[i];
                        <button class="week-tab @(i == 0 ? "active" : "")"
                                data-target="@(phaseId)-week@(w.WeekNumber)"
                                onclick="switchWeekTab(this)"
                                data-phase-num="@Model.PhaseNumber">
                            Semaine @w.WeekNumber
                        </button>
                    }
                </div>

                @* ── PANELS — UN PAR SEMAINE ── *@
                <div class="phase-week-panels">
                    @for (int i = 0; i < allWeeks.Count; i++)
                    {
                        var week = allWeeks[i];

                        @* Filtre : seulement les stagiaires ayant cette semaine *@
                        var rowsForWeek = Model.Rows
                            .Where(r => r.Weeks.Any(w => w.WeekNumber == week.WeekNumber))
                            .ToList();

                        <div id="@(phaseId)-week@(week.WeekNumber)"
                             class="phase-week-panel @(i == 0 ? "active" : "")">

                            <div class="table-container" style="margin-top:0;">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Stagiaire</th>
                                            <th>Mentor</th>
                                            <th>Cours</th>
                                            <th>Date début</th>
                                            <th>Date fin</th>
                                            <th>Statut</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!rowsForWeek.Any())
                                        {
                                            <tr>
                                                <td colspan="7"
                                                    style="text-align:center; color:var(--text-light); padding:1.5rem;">
                                                    <i class="fas fa-inbox" style="margin-right:6px;"></i>
                                                    Aucun stagiaire assigné à la semaine @week.WeekNumber
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var row in rowsForWeek)
                                            {
                                                @* Récupère les données de la semaine pour CE stagiaire *@
                                                var weekData = row.Weeks
                                                    .First(w => w.WeekNumber == week.WeekNumber);

                                                <tr>
                                                    <td>@row.TraineeName</td>
                                                    <td>@(string.IsNullOrEmpty(row.MentorName) ? "—" : row.MentorName)</td>
                                                    <td>@weekData.Course</td>
                                                    <td>@weekData.StartDate.ToString("dd/MM/yyyy")</td>
                                                    <td>@weekData.EndDate.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        @await Html.PartialAsync(
                                                            "~/Views/Shared/Components/_StatusBadge.cshtml",
                                                            weekData.Status.ToString())
                                                    </td>
                                                    <td>
                                                        <div class="action-btns">

                                                            @* Crayon → modal modification *@
                                                            <button type="button"
                                                                    class="action-btn edit"
                                                                    onclick="openPhaseEditModal(this)"
                                                                    data-phase-id="@row.PhaseId"
                                                                    data-week-id="@weekData.Id"
                                                                    data-trainee-name="@row.TraineeName"
                                                                    data-mentor-name="@row.MentorName"
                                                                    data-phase-status="@row.Status"
                                                                    data-week-status="@weekData.Status"
                                                                    data-week-number="@week.WeekNumber"
                                                                    data-course="@weekData.Course"
                                                                    data-start-date="@weekData.StartDate.ToString("yyyy-MM-dd")"
                                                                    data-end-date="@weekData.EndDate.ToString("yyyy-MM-dd")"
                                                                    aria-label="Modifier @row.TraineeName semaine @week.WeekNumber">
                                                                <i class="fas fa-pen"></i>
                                                            </button>

                                                            @* Poubelle → supprime uniquement cette semaine *@
                                                            <button type="button"
                                                                    class="action-btn delete"
                                                                    data-delete-url="/Week/Delete/@weekData.Id"
                                                                    data-delete-name="la semaine @week.WeekNumber de @row.TraineeName"
                                                                    aria-label="Supprimer la semaine @week.WeekNumber de @row.TraineeName">
                                                                <i class="fas fa-trash"></i>
                                                            </button>

                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    }
                </div>
            }
        }

    </div>
</div>
