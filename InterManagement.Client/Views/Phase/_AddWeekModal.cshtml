@*
=================================================
MODAL AJOUTER UNE SEMAINE
=================================================
*@
<div id="addWeekModal" class="modal">
    <div class="modal-content" style="max-width: 520px;">
        <div class="modal-header">
            <h3><i class="fas fa-plus-circle"></i> Ajouter une semaine</h3>
            <button class="modal-close"
                    onclick="closeModal('addWeekModal')">&times;</button>
        </div>

        <form method="post" asp-controller="Week" asp-action="Create"
              id="addWeekForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PhaseId" id="addWeekPhaseId" />

            <div class="modal-body">

                <div class="form-group">
                    <label for="addWeekNumber">Numéro de semaine</label>
                    <input type="number" name="WeekNumber" id="addWeekNumber"
                           min="1" placeholder="ex: 6" required />
                    <small style="color:var(--text-light); font-size:0.8rem;">
                        Vous pouvez entrer n'importe quel numéro (1, 6, 10, 15...).
                        Un doublon sera refusé automatiquement.
                    </small>
                </div>

                <div class="form-group">
                    <label for="addWeekCourse">Cours</label>
                    <input type="text" name="Course" id="addWeekCourse"
                           placeholder="ex: Introduction à C#" autocomplete="off" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="addWeekStart">Date début</label>
                        <input type="date" name="StartDate" id="addWeekStart" required />
                    </div>
                    <div class="form-group">
                        <label for="addWeekEnd">Date fin</label>
                        <input type="date" name="EndDate" id="addWeekEnd" required />
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn-secondary"
                        onclick="closeModal('addWeekModal')">Annuler</button>
                <button type="submit" class="btn-primary">
                    <i class="fas fa-plus"></i> Ajouter
                </button>
            </div>
        </form>
    </div>
</div>